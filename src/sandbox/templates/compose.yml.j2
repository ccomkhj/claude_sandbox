name: {{ session_id | lower }}

services:
  proxy:
    image: {{ proxy_image }}
    networks: [agent_net, proxy_egress_net]
    healthcheck:
      test: ["CMD-SHELL", "bash -c 'echo > /dev/tcp/127.0.0.1/3128' 2>/dev/null"]
      interval: 5s
      timeout: 3s
      retries: 30

  db:
    image: {{ db_image }}
    environment:
      POSTGRES_HOST_AUTH_METHOD: trust
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: postgres
    networks: [db_net]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ db_name }}"]
      interval: 5s
      timeout: 3s
      retries: 60

  agent:
    image: {{ agent_image_name }}:{{ session_id }}
    build:
      context: {{ build_dir_agent }}
    depends_on:
      db:
        condition: service_healthy
    environment:
      {{ auth_env_name }}: {{ auth_env_value | tojson }}
      GOAL: {{ goal | tojson }}
      BRANCH: sandbox/{{ session_id }}
      DATABASE_URL: postgresql://postgres@db:5432/{{ db_name }}
      HTTPS_PROXY: "http://proxy:3128"
      HTTP_PROXY: "http://proxy:3128"
      NO_PROXY: "db,localhost,127.0.0.1"
{% if aws_credentials %}
      AWS_ACCESS_KEY_ID: {{ aws_credentials.access_key_id | tojson }}
      AWS_SECRET_ACCESS_KEY: {{ aws_credentials.secret_access_key | tojson }}
{% if aws_credentials.session_token %}
      AWS_SESSION_TOKEN: {{ aws_credentials.session_token | tojson }}
{% endif %}
      AWS_REGION: {{ aws_credentials.region | tojson }}
{% endif %}
    networks: [agent_net, db_net]

networks:
  agent_net:
    driver: bridge
    internal: true
  proxy_egress_net:
    driver: bridge
  db_net:
    driver: bridge
    internal: true

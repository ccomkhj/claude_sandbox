name: {{ session_id | lower }}

services:
  proxy:
    image: {{ proxy_image }}
    networks: [agent_net, proxy_egress_net]
    healthcheck:
      test: ["CMD-SHELL", "squidclient -h 127.0.0.1 cache_object://localhost/info >/dev/null 2>&1 || exit 1"]
      interval: 5s
      timeout: 3s
      retries: 30

  db:
    image: {{ db_image }}
    environment:
      POSTGRES_HOST_AUTH_METHOD: trust
      POSTGRES_DB: {{ db_name }}
      POSTGRES_USER: postgres
    networks: [db_net]
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ db_name }}"]
      interval: 5s
      timeout: 3s
      retries: 60

  agent:
    image: {{ agent_image_name }}:{{ session_id }}
    build:
      context: {{ build_dir_agent }}
    depends_on:
      db:
        condition: service_healthy
    environment:
      GOAL: {{ goal | tojson }}
      BRANCH: sandbox/{{ session_id }}
      DATABASE_URL: postgresql://postgres@db:5432/{{ db_name }}
      HTTPS_PROXY: "http://proxy:3128"
      HTTP_PROXY: "http://proxy:3128"
      NO_PROXY: "db,localhost,127.0.0.1"
    networks: [agent_net, db_net]

networks:
  agent_net:
    driver: bridge
    internal: true
  proxy_egress_net:
    driver: bridge
  db_net:
    driver: bridge
    internal: true
